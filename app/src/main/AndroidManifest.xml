<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <application
        android:name="com.oneThing.onething.App"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.OneThing"
        tools:targetApi="31">
        <activity
            android:name="com.oneThing.login.LoginActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.OneThing">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name="com.oneThing.kakao.com.kakao.sdk.auth.AuthCodeHandlerActivity"
            android:exported="true"
            android:theme="@style/Theme.AppCompat.Light.NoActionBar">
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />

                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />

                <data
                    android:host="oauth"
                    android:scheme="kakao${NATIVE_APP_KEY}" />
            </intent-filter>
        </activity>

        <activity
            android:name="com.oneThing.signup.SignUpActivity"
            android:exported="true"
            android:theme="@style/Theme.AppCompat.Light.NoActionBar" />

        <activity
            android:name="com.oneThing.main.MainActivity"
            android:exported="true" />

        <activity
            android:name="com.oneThing.editprofile.ProfileEditMainActivity"
            android:exported="true" />

        <activity
            android:name="com.oneThing.report.ReportMainActivity"
            android:exported="true" />

        <activity
            android:name="com.oneThing.low.ui.low.LowActivity"
            android:exported="true" />

        <activity
            android:name="com.oneThing.alarm.AlarmMainActivity"
            android:exported="true" />

        <activity
            android:name="com.oneThing.onethingmatch.OneThinMatchActivity"
            android:exported="true" />

        <activity
            android:name="com.oneThing.billing.BillingActivity"
            android:exported="true"
            android:theme="@style/Theme.AppCompat.NoActionBar" />

        <activity
            android:name="com.tosspayments.paymentsdk.activity.TossPaymentActivity"
            android:exported="false"
            android:theme="@style/Theme.AppCompat.Light.NoActionBar" />

        <activity
            android:name="com.oneThing.pay_finish.PayFinishActivity"
            android:exported="false" />

        <activity
            android:name="com.oneThing.first_matrch.FirstMatchActivity"
            android:exported="true" />

        <activity
            android:name="com.oneThing.random.RandomMatchActivity"
            android:exported="true" />

        <activity
            android:name="com.oneThing.guide.GuideActivity"
            android:exported="true" />

        <service
            android:name="com.oneThing.fcm.FirebaseMessage"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>
    </application>
</manifest>